---
extends: default

rules:
  line-length:
    max: 220
    level: warning
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']
    check-keys: false
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  document-start: disable
  indentation:
    spaces: 2
    indent-sequences: consistent
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: false
    forbid-explicit-octal: false

ignore: |
  .ansible/
  .cache/
  molecule/*/
