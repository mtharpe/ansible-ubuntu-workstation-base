# {{ ansible_managed }}

[DEFAULT]
backend = systemd
usedns = no
banaction = ufw

bantime  = 3600
findtime = 600
maxretry = 3

# Progressive bans for repeat offenders: each ban doubles in length up to a
# week. Requires fail2ban >= 0.11 (Ubuntu 22.04+ is fine).
bantime.increment = true
bantime.maxtime   = 604800
bantime.factor    = 2

# Set `local_network` (e.g. "192.168.1.0/24") in vars.yml to exempt a trusted
# subnet from bans. Without it, only loopback is exempt.
ignoreip = 127.0.0.1/8 ::1 {{ local_network | default('') }}

# Default action is ban-only — workstations rarely have a working MTA, so
# action_mwl (mail+WHOIS+log) would just emit silent failures. Switch to
# %(action_mwl)s manually if destemail points to a real address and the host
# can send mail.
destemail = {{ local_user_email }}
sender    = fail2ban@{{ ansible_facts['nodename'] }}
action    = %(action_)s

[sshd]
enabled = true

# Recidive watches fail2ban's own log (/var/log/fail2ban.log) to chain-ban
# IPs that keep getting banned. It tails a file, so it can't use the
# systemd backend set above — override per-jail.
[recidive]
enabled  = true
backend  = auto
logpath  = /var/log/fail2ban.log
bantime  = 604800
findtime = 86400
maxretry = 5
